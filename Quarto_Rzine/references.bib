@misc{bourgeatIndicateursIndices2023,
  type = {{Glossaire}},
  title = {{Indicateurs et indices}},
  author = {Bourgeat, Serge and Bras, Catherine},
  year = 2023,
  month = jun,
  journal = {G\'eoconfluences},
  publisher = {\'Ecole normale sup\'erieure de Lyon},
  address = {Lyon},
  urldate = {2026-03-04},
  abstract = {Un indice est une <<~indication num\'erique qui sert \`a exprimer un rapport math\'ematique~>> (Lacoste, 2003) comme par exemple dans le cas de l'indice de f\'econdit\'e d'une population. Un indicateur (\'etymologiquement, <<~ce qui indique~>>) est, en g\'eographie, un ensemble composite de donn\'ees qui permettent de caract\'eriser une situation complexe. L'indicateur composite est forg\'e \`a partir de plusieurs param\`etres permettant de rendre compte au mieux d'une situation. Il se b\^atit donc \`a partir de plusieurs indices, comme par exemple dans le cas de l'IDH, ou de l'indice de nordicit\'e qui sont -- au sens strict et malgr\'e leur nom -- des indicateurs. En fait, dans la pratique courante, les deux termes sont souvent intervertis, d'autant plus qu'\'economistes, organisations internationales et instituts statistiques donnent des d\'efinitions diff\'erentes et parfois contradictoires de ces termes~: ainsi l'INSEE m\^ele indices et indicateurs dans sa liste des <<~indicateurs statistiques~>>.  Dans une g\'eographie \`a la recherche de lois g\'en\'erales et soucieuse de s'\'emanciper d'une tentation idiographique, l'utilisation d'indices et d'indicateurs s'est accentu\'ee dans les ann\'ees 1960-1970, car ils fournissent une valeur num\'erique qui permet de mieux caract\'eriser et comprendre tel ou tel ph\'enom\`ene, ou de comparer plusieurs territoires. Il existe donc de tr\`es nombreux indices et indicateurs~: dans le Dictionnaire de g\'eographie (Baud, Bourgeat et Bras, 2022) sont mentionn\'es 24~indicateurs et indices couramment utilis\'es en g\'eographie. De son c\^ot\'e, l'Insee en utilise habituellement 36.  (SB et CB) juin 2023  R\'ef\'erences cit\'ees 	  - Baud Pascal, Bourgeat Serge et Bras Catherine (2022), Dictionnaire de g\'eographie. Hatier 2022. 6e \'edition 	  - INSEE. Liste des indicateurs statistiques. 	  - Lacoste Yves (2003). De la g\'eopolitique aux paysages. Armand Colin. 2003. Pour compl\'eter avec G\'eoconfluences 	  - Dans le glossaire : empreinte \'ecologique \textbar{} indicateurs du d\'eveloppement durable \textbar{} indicateurs de sant\'e \textbar{} statistiques et indicateurs 	  - Sur l'indice de positionnement social :~Lucie Kouadria, <<~Le profil social des lyc\'ees en France~: une analyse de l'IPS (indice de positionnement social) par la DEPP~>>, G\'eoconfluences, mai 2025.},
  copyright = {Sauf mention contraire, ressource sous licence CC 4.0 BY-NC-SA},
  howpublished = {https://geoconfluences.ens-lyon.fr/glossaire/indicateurs},
  langid = {french},
  file = {/home/tristan/Zotero/storage/56X5JT29/indicateurs.html}
}

@article{delclos-alio_2018,
  title = {Looking at {{Barcelona}} through {{Jane Jacobs}}'s Eyes: {{Mapping}} the Basic Conditions for Urban Vitality in a {{Mediterranean}} Conurbation},
  shorttitle = {Looking at {{Barcelona}} through {{Jane Jacobs}}'s Eyes},
  author = {{Delcl{\`o}s-Ali{\'o}}, Xavier and {Miralles-Guasch}, Carme},
  year = 2018,
  month = jun,
  journal = {Land Use Policy},
  volume = {75},
  pages = {505--517},
  issn = {0264-8377},
  doi = {10.1016/j.landusepol.2018.04.026},
  urldate = {2023-03-24},
  abstract = {Jane Jacobs' quest for urban vitality has had an indisputable influence for urban researchers and planners especially in the Anglo-American context, yet her theories have reached smaller audiences in other parts of the world. This is especially the case in the Mediterranean context, in which her principles for urban vitality would very well correspond to the traditional attributes of these urban settlements, even though their inherent vital nature has been progressively challenged under the paradigm of modernity. In order to contribute with the efforts conducted in the past few years aimed at empirically testing Jacobs' ideas, we consider of special interest to question the nature of these new urban configurations by analyzing Barcelona (Spain) through Jacobs's eyes. An analysis of urban vitality throughout a systemized approach has allowed a detailed spatial interpretation of a conurbation that combines both the attributes of traditional Mediterranean cities and the conflicts that modernity brought with it. The approach that Jacobs provided has proven useful to highlight that this urban area is far from homogeneous, and therefore is also presented as a useful framework for other researchers and urban practitioners to study urban vitality in different geographic contexts, especially in those areas where the logics of modern city building may still persevere.},
  langid = {english},
  keywords = {Barcelona,Built environment,GIS,Jane Jacobs,Mediterranean city,Urban vitality},
  file = {/home/tristan/Zotero/storage/JXYQ8FEW/S0264837717314175.html}
}

